{
  "name": "@driftdev/openapi-adapter",
  "version": "1.0.1",
  "description": "OpenAPI adapter for Drift - maps OpenAPI 3.x documents to ApiSpec",
  "keywords": [
    "openapi",
    "rest",
    "drift",
    "documentation",
    "api"
  ],
  "homepage": "https://github.com/ryanwaits/drift#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanwaits/drift.git",
    "directory": "packages/adapters/openapi"
  },
  "license": "MIT",
  "author": "Ryan Waits",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bunup",
    "dev": "bunup --watch",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@driftdev/sdk": "^1.3.0"
  },
  "devDependencies": {
    "@driftdev/sdk": "workspace:*",
    "@types/bun": "^1.3.14",
    "bunup": "0.16.26"
  },
  "publishConfig": {
    "access": "public"
  }
}
