{
  "name": "@driftdev/sdk",
  "version": "1.8.0",
  "description": "Drift SDK - detect when your docs drift from your code",
  "keywords": [
    "typescript",
    "documentation",
    "sdk",
    "drift",
    "docs-coverage",
    "drift-detection",
    "openapi",
    "rest",
    "api",
    "agent",
    "mcp"
  ],
  "homepage": "https://github.com/ryanwaits/drift#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanwaits/drift.git",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "author": "Ryan Waits",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./analysis": {
      "import": "./dist/analysis/index.js",
      "types": "./dist/analysis/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./markdown": {
      "import": "./dist/markdown/index.js",
      "types": "./dist/markdown/index.d.ts"
    },
    "./examples": {
      "import": "./dist/examples/index.js",
      "types": "./dist/examples/index.d.ts"
    },
    "./history": {
      "import": "./dist/history/index.js",
      "types": "./dist/history/index.d.ts"
    },
    "./cache": {
      "import": "./dist/cache/index.js",
      "types": "./dist/cache/index.d.ts"
    }
  },
  "scripts": {
    "build": "bunup",
    "dev": "bunup --watch",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@openpkg-ts/sdk": "^0.38.0",
    "@openpkg-ts/spec": "^0.37.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "remark-mdx": "^3.1.0",
    "remark-parse": "^11.0.0",
    "typescript": "^5.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.0.0",
    "@vercel/sandbox": "^2.5.0",
    "bunup": "0.16.26"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  }
}
