{
  "name": "@driftdev/cli",
  "version": "1.10.0",
  "description": "Drift CLI - detect when your docs drift from your code",
  "keywords": [
    "typescript",
    "cli",
    "documentation",
    "drift",
    "docs-coverage",
    "drift-detection",
    "openapi",
    "rest",
    "api",
    "agent",
    "mcp"
  ],
  "homepage": "https://github.com/ryanwaits/drift#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanwaits/drift.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "Ryan Waits",
  "type": "module",
  "bin": {
    "drift": "./dist/drift.js"
  },
  "scripts": {
    "build": "bunup",
    "dev": "bunup --watch",
    "cli": "bun run src/drift.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "prepublishOnly": "bun run build",
    "test": "bun run --cwd ../sdk build && bun run --cwd ../adapters/clarity build && bun run --cwd ../adapters/openapi build && for f in test/*.test.ts; do bun test \"$f\" || exit 1; done"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@driftdev/clarity-adapter": "^1.0.1",
    "@driftdev/openapi-adapter": "^1.0.1",
    "@driftdev/sdk": "^1.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openpkg-ts/sdk": "^0.40.0",
    "@openpkg-ts/spec": "^0.37.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "bunup": "0.16.26"
  },
  "publishConfig": {
    "access": "public"
  }
}
