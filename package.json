{
  "name": "drift",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/adapters/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run build:sdk && bun run build:cli && bun run build:clarity-adapter && bun run build:openapi-adapter",
    "build:clarity-adapter": "cd packages/adapters/clarity && bun run build",
    "build:openapi-adapter": "cd packages/adapters/openapi && bun run build",
    "build:sdk": "cd packages/sdk && bun run build",
    "build:cli": "cd packages/cli && bun run build",
    "dev": "bun run --parallel dev:sdk dev:cli",
    "dev:sdk": "cd packages/sdk && bun run dev",
    "dev:cli": "cd packages/cli && bun run dev",
    "typecheck": "tsc -p packages/sdk --noEmit && tsc -p packages/cli --noEmit && tsc -p packages/adapters/clarity --noEmit && tsc -p packages/adapters/openapi --noEmit && tsc -p apps/site --noEmit",
    "lint": "bunx biome check packages/ apps/",
    "lint:fix": "bunx biome check --write packages/ apps/",
    "format": "bunx biome format --write packages/ apps/",
    "changeset": "changeset",
    "version": "changeset version && bun install",
    "release": "bun run build && changeset publish",
    "dev:site": "cd apps/site && bun dev",
    "build:site": "cd apps/site && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.3",
    "typescript": "^5.9.3"
  }
}
